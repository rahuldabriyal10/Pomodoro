rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Rules for the main 'users' collection
    match /users/{userId} {
      
      // LEADERBOARD RULE: Any logged-in user can read all profiles (to see names & scores)
      allow read: if request.auth != null; 
      
      // SECURITY RULE: Only the actual owner can edit their profile or stats
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // 2. Rules for the 'projects' subcollection
      match /projects/{projectId} {
        // PRIVACY RULE: Only the owner can see or edit their own projects
        allow read, write: if request.auth != null && request.auth.uid == userId;
        
        // 3. Rules for the 'tasks' subcollection inside projects
        match /tasks/{taskId} {
          // PRIVACY RULE: Only the owner can see or edit their own tasks
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }
    }
  }
}